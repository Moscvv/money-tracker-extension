{
    "manifest_version": 3,
    "name": "Money Tracker",
    "version": "1.0",
    "description": "A private, local-only personnal finance tracker.",
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": ["storage", "tabs"],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}